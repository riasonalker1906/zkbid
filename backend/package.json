{
  "name": "zkbid-backend",
  "version": "0.1.0",
  "private": true,
  "description": "ZKBid auctioneer backend: collects encrypted bids, decrypts after window close, generates ZK proof, and (later) submits on-chain.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test:e2e": "tsx test/e2e.ts",
    "test:onchain": "tsx test/onchain.ts",
    "compile:verifier": "tsx scripts/check-compile.ts",
    "deploy:verifier": "tsx scripts/deploy-verifier.ts",
    "verify:onchain": "tsx scripts/verify-onchain.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ethers": "^6.13.2",
    "express": "^4.19.2",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "hardhat": "^3.4.1",
    "solc": "^0.8.28",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
