# HTTP server
PORT=8080

# Path to the circuit workspace (relative paths are resolved from backend/)
CIRCUIT_DIR=../circuit

# Auctioneer state directory (keypair + bids + run artifacts)
DATA_DIR=./data

# How many bidder slots the circuit expects. MUST match circuit/src/main.nr.
NUM_SLOTS=5

# Commitment source: "mock" reads from $DATA_DIR/commitments.json, "ethers" reads from chain.
COMMITMENTS_SOURCE=mock

# Chain connection (used both by COMMITMENTS_SOURCE=ethers and the on-chain
# deploy/verify scripts below).
RPC_URL=http://127.0.0.1:8545

# Auction contract (only needed for COMMITMENTS_SOURCE=ethers)
AUCTION_ADDRESS=

# On-chain verifier testing (scripts/deploy-verifier.ts + verify-onchain.ts)
# Private key of the account that will deploy the HonkVerifier contract.
# NEVER use a key that holds real funds here -- use a dedicated dev account.
# For local anvil/hardhat, any prefunded key works.
PRIVATE_KEY=
# Address of the deployed HonkVerifier. Set manually, or leave blank and let
# deploy-verifier.ts write it to data/verifier-address.json.
VERIFIER_ADDRESS=

# Development-only: allow POST /reset to wipe auction state
ALLOW_RESET=true
